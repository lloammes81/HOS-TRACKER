{
  "appId": "com.lloammes81.hostracker",
  "appName": "HOS Tracker",
  "webDir": "www",
  "server": {
    "androidScheme": "https"
  },
  "ios": {
    "scheme": "HOS Tracker",
    "backgroundColor": "#0b173a"
  },
  "plugins": {
    "LocalNotifications": {
      "smallIcon": "ic_stat_icon_config_sample",
      "iconColor": "#10b981",
      "sound": "beep.wav"
    },
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0b173a",
      "androidSplashResourceName": "splash",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": false,
      "splashFullScreen": true,
      "splashImmersive": true
    }
  }
}
